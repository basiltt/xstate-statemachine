{
  "id": "DebtState",
  "initial": "ActiveDebt",
  "states": {
    "ActiveDebt": {
      "on": {
        "CloseDebt": [
          {
            "actions": [],
            "guard": "onlyClosedLoan",
            "target": "ClosedDebt"
          }
        ],
        "MakeDebtOverdue": [
          {
            "actions": [],
            "guard": "and",
            "target": "OverdueDebt"
          }
        ]
      }
    },
    "ClosedDebt": {
      "type": "final"
    },
    "OverdueDebt": {
      "on": {
        "ChangeOverdueDebtToActive": [
          {
            "actions": [],
            "guard": "and",
            "target": "ActiveDebt"
          }
        ],
        "CloseDebt": [
          {
            "actions": [],
            "guard": "onlyClosedLoan",
            "target": "ClosedDebt"
          }
        ]
      }
    }
  }
}
