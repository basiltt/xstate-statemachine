          "type": "final"
        }
      },
      "type": "final"
    },
    "OverdueDebt": {
      "initial": "OverdueLoan",
      "states": {
        "OverdueLoan": {
          "on": {
            "LOAN_DEFER": [
              {
                "actions": [],
                "target": "#debt.ActiveDebt"
              }
            ],
            "LOAN_PAY": [
              {
                "actions": [],
                "target": "#debt.ClosedDebt"
              }
            ]
          }
        }
      }
    }
