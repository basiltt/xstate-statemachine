{
  "id": "debt",
  "initial": "ActiveDebt",
  "states": {
    "ActiveDebt": {
      "initial": "ActiveLoan",
      "states": {
        "ActiveLoan": {
          "on": {
            "LOAN_OVERDUE": [
              {
                "actions": [],
                "target": "#debt.OverdueDebt"
              }
            ],
            "LOAN_PAY": [
              {
                "actions": [],
                "target": "#debt.ClosedDebt"
              }
            ]
          }
        }
      }
    },
    "ClosedDebt": {
      "initial": "ClosedLoan",
      "states": {
