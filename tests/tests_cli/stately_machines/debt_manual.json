{
  "id": "debt \u0440\u0443\u0447\u043d\u0430\u044f \u0438\u0442\u043e\u0433\u043e\u0432\u0430\u044f \u0432\u0435\u0440\u0441\u0438\u044f",
  "initial": "ActiveDebt",
  "states": {
    "ActiveDebt": {
      "on": {
        "makeClosed": [
          {
            "actions": [],
            "guard": "onlyClosedLoans",
            "target": "ClosedDebt"
          }
        ],
        "makeOverdue": [
          {
            "actions": [],
            "guard": "anyLoanOverdue",
            "target": "OverdueDebt"
          }
        ]
      }
    },
    "ClosedDebt": {
      "type": "final"
    },
    "OverdueDebt": {
      "on": {
        "makeActive": [
          {
            "actions": [],
            "guard": "onlyActiveOrClosedLoans",
            "target": "ActiveDebt"
          }
        ],
        "makeClosed": [
          {
            "actions": [],
            "guard": "onlyClosedLoans",
            "target": "ClosedDebt"
          }
        ]
      }
    }
  }
}
